# =============================================================================
# VERCEL ENVIRONMENT VARIABLES — add ALL of these in Vercel Dashboard
# Project → Settings → Environment Variables → Add Environment Variable
# Enable for: Production, Preview, and Development
# =============================================================================

# --- FRONTEND (public — shown in browser) ---
NEXT_PUBLIC_API_URL=https://arowwai-fashion-store.vercel.app/api
NEXT_PUBLIC_APP_URL=https://arowwai-fashion-store.vercel.app

# Deploy checklist (Vercel → Project → Settings → Environment Variables):
# 1) NEXT_PUBLIC_API_URL = your production URL ending in /api (same host as this frontend).
# 2) GITHUB_TOKEN + GITHUB_AI_MODEL on the SERVER (not NEXT_PUBLIC_*). Token needs GitHub Models / models:read.
# 3) After changing env vars, trigger a new deployment (Redeploy).

NEXT_PUBLIC_FIREBASE_API_KEY=AIzaSyAYvUEa6vax3WNwe8cr7x_0KDTQYc5yRcQ
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=fashion-mate-mawanella.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=fashion-mate-mawanella
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=fashion-mate-mawanella.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=978918965075
NEXT_PUBLIC_FIREBASE_APP_ID=1:978918965075:web:db285a61b6823944306ba6
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=G-MV4WPTVX7Z

# --- BACKEND (server — keep secret, same Vercel project) ---
NODE_ENV=production
FRONTEND_URL=https://arowwai-fashion-store.vercel.app

# MongoDB Atlas (use your connection string from backend/.env)
MONGODB_URI=your_mongodb_connection_string
MONGODB_URI_SRV=your_mongodb_srv_connection_string_optional

# JWT auth (use same values as backend/.env)
JWT_SECRET=your_jwt_secret
JWT_EXPIRE=7d
JWT_REFRESH_SECRET=your_jwt_refresh_secret
JWT_REFRESH_EXPIRE=30d

# GitHub AI (GITHUB_TOKEN + GITHUB_AI_MODEL) is read only on the BACKEND API — set them in backend/.env or Vercel server env, not in the browser.

# Firebase Admin (optional — paste full JSON as one line if needed)
FIREBASE_PROJECT_ID=fashion-mate-mawanella
FIREBASE_SERVICE_ACCOUNT_JSON=

# Email (optional — password reset emails)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
