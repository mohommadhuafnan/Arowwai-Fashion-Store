PORT=5000
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/trendypos?retryWrites=true&w=majority&appName=POS-System
JWT_SECRET=your_super_secret_jwt_key_change_in_production
JWT_EXPIRE=7d
JWT_REFRESH_SECRET=your_refresh_secret_key
JWT_REFRESH_EXPIRE=30d
FRONTEND_URL=http://localhost:3000
NODE_ENV=development
# Product images → Cloudinary (HTTPS URL in MongoDB). On Vercel use ONE of:
# (A) Recommended — single line from Cloudinary dashboard "API environment variable":
#     CLOUDINARY_URL=cloudinary://API_KEY:API_SECRET@CLOUD_NAME
# (B) Or three separate variables:
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret
# Optional folder in Cloudinary (no leading/trailing slashes)
CLOUDINARY_FOLDER=trendypos/products
# GitHub Models inference (https://models.github.ai/inference) — requests use your GITHUB_TOKEN (Microsoft-hosted endpoint per GitHub).
# Create ONE secret: classic PAT with models access, OR fine-grained PAT with “Models” / models:read permission. Never commit real tokens.
GITHUB_TOKEN=
# Model id from GitHub Models catalog, e.g. openai/gpt-4o-mini. External models: custom/key_id/model_id
GITHUB_AI_MODEL=openai/gpt-4o-mini
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
